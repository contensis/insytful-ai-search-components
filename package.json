{
  "name": "insytful-ai-search-components",
  "description": "An accessible, AI-powered search modal component library built with React, TypeScript, and Tailwind CSS",
  "version": "0.1.1-beta.1",
  "author": "Zengenti",
  "license": "MIT",
  "keywords": [
    "react",
    "components",
    "ai",
    "search",
    "modal",
    "web-components",
    "shadow-dom",
    "tailwind",
    "typescript",
    "accessibility"
  ],
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "module": "./dist/insytful-ai-search-components.js",
  "types": "./dist/types/main.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/main.d.ts",
      "import": "./dist/insytful-ai-search-components.js",
      "default": "./dist/insytful-ai-search-components.js"
    },
    "./theme.css": "./dist/insytful-ai-search-components.css"
  },
  "scripts": {
    "dev": "vite",
    "prebuild": "rimraf dist",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "pack": "npm run build && npm pack",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "contensis-rag-react": "^0.3.4",
    "focus-trap": "^7.8.0"
  },
  "peerDependencies": {
    "react": ">=17",
    "react-dom": ">=17"
  },
  "overrides": {
    "@types/react": "^18.3.25",
    "@types/react-dom": "^18.3.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^18.3.25",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.24",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "rehype-external-links": "^3.0.0",
    "rimraf": "^6.1.2",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4"
  }
